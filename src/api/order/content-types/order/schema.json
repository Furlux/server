{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "telegramUserId": {
      "type": "biginteger",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "processing", "shipped", "delivered", "cancelled"],
      "default": "pending",
      "required": true
    },
    "totalPrice": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "default": "UAH"
    },
    "items": {
      "type": "json",
      "required": true
    },
    "firstName": {
      "type": "string",
      "required": true
    },
    "lastName": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "city": {
      "type": "string",
      "required": true
    },
    "deliveryMethod": {
      "type": "enumeration",
      "enum": ["nova-poshta-warehouse", "nova-poshta-address"],
      "required": true
    },
    "warehouseNumber": {
      "type": "string"
    },
    "streetAddress": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "comment": {
      "type": "text"
    },
    "monoInvoiceId": {
      "type": "string"
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": ["pending", "paid", "failed"],
      "default": "pending"
    }
  }
}
