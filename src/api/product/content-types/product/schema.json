{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Products"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "salePrice": {
      "type": "decimal"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "currency": {
      "type": "string"
    },
    "attributes": {
      "type": "json"
    },
    "available": {
      "type": "boolean"
    },
    "isNew": {
      "type": "boolean"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "articleNumber": {
      "type": "string"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "children",
        "women",
        "men",
        "unisex"
      ]
    },
    "photoFormat": {
      "type": "enumeration",
      "enum": [
        "catalog",
        "standard",
        "legacy"
      ],
      "default": "standard"
    },
    "variants": {
      "type": "component",
      "repeatable": true,
      "component": "product.product-variant"
    },
    "productStatus": {
      "type": "enumeration",
      "enum": ["active", "archive"],
      "default": "active"
    },
    "supplierCode": {
      "type": "string"
    },
    "stockQuantity": {
      "type": "integer"
    },
    "sizes": {
      "type": "string"
    },
    "lensType": {
      "type": "enumeration",
      "enum": ["поляризовані", "сонцезахисні", "хамелеон", "комп'ютер", "нейлон"]
    },
    "isBrand": {
      "type": "boolean",
      "default": false
    },
    "frameType": {
      "type": "enumeration",
      "enum": ["метал", "пластик", "безоправні", "комбінована"]
    },
    "color": {
      "type": "json"
    },
    "frameShape": {
      "type": "enumeration",
      "enum": ["авіатор", "ромби", "навігатор", "круглі", "прямокутник", "квадрат", "трапеція", "багатокутник", "оверсайз", "маска", "кішка"]
    },
    "hasClipon": {
      "type": "boolean",
      "default": false
    }
  }
}
