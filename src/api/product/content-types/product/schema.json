{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Products"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "salePrice": {
      "type": "decimal"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "currency": {
      "type": "string"
    },
    "attributes": {
      "type": "json"
    },
    "available": {
      "type": "boolean"
    },
    "isNew": {
      "type": "boolean"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "brand": {
      "type": "string"
    },
    "lensType": {
      "type": "enumeration",
      "enum": [
        "gradient",
        "polarized"
      ]
    },
    "uvProtection": {
      "type": "string"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "children",
        "women",
        "men",
        "unisex"
      ]
    },
    "shape": {
      "type": "enumeration",
      "enum": [
        "aviator",
        "square",
        "round",
        "cat-eye",
        "panto",
        "mask",
        "rounded",
        "butterfly",
        "non-standard",
        "oval",
        "rectangular"
      ]
    },
    "collectionYear": {
      "type": "enumeration",
      "enum": [
        "y2025",
        "y2026"
      ]
    },
    "frameMaterial": {
      "type": "enumeration",
      "enum": [
        "acetate",
        "metal",
        "plastic",
        "titanium"
      ]
    },
    "lensMaterial": {
      "type": "enumeration",
      "enum": [
        "mineral",
        "glass"
      ]
    },
    "photoFormat": {
      "type": "enumeration",
      "enum": [
        "catalog",
        "standard",
        "legacy"
      ],
      "default": "standard"
    },
    "variants": {
      "type": "component",
      "repeatable": true,
      "component": "product.product-variant"
    }
  }
}
